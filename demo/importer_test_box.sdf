<?xml version="1.0"?>
<!--
  Minimal importer test model — robot_importer_gui MVP validation

  Purpose: validate the full importer flow (preview → pose → import) without
  any noise from physics engine limitations:
    - No mesh geometry: all shapes are primitives (box, sphere, cylinder).
      Avoids dartsim "collision geometry not created" warnings.
    - No <inertial><auto>: all inertia is explicit.
      Avoids "Inertial is set to auto but no <collision>" warnings.
    - No <plugin> elements: no ROS2 or gz sensor plugins.
      The stripped preview SDF is identical to the full SDF minus nothing.
    - Two links with a fixed joint: exercises joint handling in the SDF pipeline.

  Expected importer behaviour:
    Preview:
      - preparePreviewSdf() strips zero <plugin> elements (none present).
      - <static>true</static> is injected → model stays in place.
      - No engine warnings expected.
    Final import:
      - Full SDF sent unchanged (URI rewrite + instance name only).
      - Physics runs: two links, one joint, explicit inertia.
      - No engine warnings expected.

  Usage:
    gz sim empty.sdf          # launch Gazebo
    Open Robot Importer GUI
    Browse → select this file
    Verify: preview appears as a blue box with a grey sphere on top.
    Move preview with transform gizmo.
    Click Import → final entity spawns at same pose.
    World stays paused. Press Play to resume.
-->
<sdf version="1.8">
  <model name="test_box">

    <link name="base">
      <pose>0 0 0.25 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0833</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
          <iyy>0.0833</iyy><iyz>0.0</iyz>
          <izz>0.0833</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box><size>0.5 0.5 0.5</size></box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box><size>0.5 0.5 0.5</size></box>
        </geometry>
        <material>
          <ambient>0.2 0.4 0.8 1</ambient>
          <diffuse>0.2 0.4 0.8 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <link name="top">
      <pose>0 0 0.65 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.01</ixx><ixy>0.0</ixy><ixz>0.0</ixz>
          <iyy>0.01</iyy><iyz>0.0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="top_collision">
        <geometry>
          <sphere><radius>0.12</radius></sphere>
        </geometry>
      </collision>
      <visual name="top_visual">
        <geometry>
          <sphere><radius>0.12</radius></sphere>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_top_fixed" type="fixed">
      <parent>base</parent>
      <child>top</child>
    </joint>

  </model>
</sdf>
