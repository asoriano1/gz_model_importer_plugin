<?xml version="1.0"?>
<!-- Test fixture for ros_gz_bridge detection.
     Covers: camera with explicit topic, gpu_lidar without topic, imu, gz_ros2_control plugin. -->
<sdf version="1.9">
  <model name="bridge_test_robot">
    <link name="base_link">

      <!-- camera with explicit topic -->
      <sensor name="front_camera" type="camera">
        <topic>/bridge_test/camera/image_raw</topic>
        <update_rate>30</update_rate>
        <camera>
          <image><width>640</width><height>480</height></image>
        </camera>
      </sensor>

      <!-- gpu_lidar WITHOUT explicit topic — topic must be inferred -->
      <sensor name="lidar_sensor" type="gpu_lidar">
        <update_rate>10</update_rate>
        <ray><scan><horizontal><samples>360</samples></horizontal></scan></ray>
      </sensor>

      <!-- imu with explicit topic -->
      <sensor name="imu_sensor" type="imu">
        <topic>/bridge_test/imu/data_raw</topic>
        <update_rate>100</update_rate>
      </sensor>

      <!-- camera with a ROS plugin child — bridge NOT needed -->
      <sensor name="rear_camera" type="camera">
        <update_rate>15</update_rate>
        <plugin filename="libgazebo_ros_camera.so" name="rear_camera_plugin">
          <ros><namespace>/bridge_test</namespace></ros>
        </plugin>
      </sensor>

    </link>

    <!-- ros2_control plugin -->
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find bridge_test_robot)/config/controllers.yaml</parameters>
    </plugin>

  </model>
</sdf>
