<?xml version="1.0"?>
<!-- Test model: plain SDF (no XACRO, no URDF conversion step).
     Used to verify the SDF-direct import path and preflight checker.
     Includes a plugin element to test plugin stripping in preview. -->
<sdf version="1.9">
  <model name="minimal_sdf_robot">

    <link name="chassis">
      <pose>0 0 0.15 0 0 0</pose>

      <visual name="chassis_visual">
        <geometry>
          <box>
            <size>0.7 0.4 0.2</size>
          </box>
        </geometry>
        <material>
          <ambient>0.2 0.5 0.2 1</ambient>
          <diffuse>0.2 0.5 0.2 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>

      <collision name="chassis_col">
        <geometry>
          <box>
            <size>0.7 0.4 0.2</size>
          </box>
        </geometry>
      </collision>

      <inertial>
        <mass>15</mass>
        <inertia>
          <ixx>0.35</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.7</iyy><iyz>0</iyz>
          <izz>0.9</izz>
        </inertia>
      </inertial>
    </link>

    <link name="lidar_link">
      <pose>0.3 0 0.3 0 0 0</pose>

      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <collision name="lidar_col">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>

      <sensor name="lidar" type="lidar">
        <pose>0 0 0.05 0 0 0</pose>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.1</min>
            <max>30.0</max>
          </range>
        </lidar>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
      </sensor>
    </link>

    <joint name="chassis_to_lidar" type="fixed">
      <parent>chassis</parent>
      <child>lidar_link</child>
    </joint>

    <!-- Intentional plugin — stripped by PreviewController::preparePreviewSdf().
         Verified in preflight report under "Plugins stripped for preview". -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.4</wheel_separation>
      <wheel_radius>0.1</wheel_radius>
    </plugin>

  </model>
</sdf>
