<?xml version="1.0" ?>
<!--
  Test world for robot_importer_gui — Gazebo Harmonic (gz-sim 8)

  Includes all sensor system plugins needed to test imported models:
    - Physics, UserCommands, SceneBroadcaster  (always required)
    - Sensors + Imu + NavSat                   (sensor pipeline)
    - Contact                                  (touch/collision sensors)

  Launch:
    gz sim test/worlds/importer_test.sdf

  Or via ros_gz_sim (sources ROS2 bridge automatically):
    ros2 launch ros_gz_sim gz_sim.launch.py \
      gz_args:="-r $(pwd)/test/worlds/importer_test.sdf"

  Then open Gazebo, load the Robot Importer GUI plugin, and import any model.
  After import, bridge sensor topics with:
    ros2 run ros_gz_bridge bridge_node \
      --ros-args -p config_file:=$(pwd)/test/models/sensor_test_bridge.yaml
-->
<sdf version="1.9">
<world name="importer_test">

  <!-- ============================================================
       PHYSICS
  ============================================================ -->
  <physics name="1ms" type="ignored">
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1.0</real_time_factor>
  </physics>

  <!-- ============================================================
       WORLD SYSTEM PLUGINS
       All sensors (IMU, lidar, camera, GPS, contact) need their
       corresponding system loaded here at world level.
  ============================================================ -->

  <!-- Core: physics simulation -->
  <plugin filename="gz-sim-physics-system"
          name="gz::sim::systems::Physics"/>

  <!-- Core: allows spawning/removing models at runtime (required by importer) -->
  <plugin filename="gz-sim-user-commands-system"
          name="gz::sim::systems::UserCommands"/>

  <!-- Core: streams scene updates to the GUI renderer -->
  <plugin filename="gz-sim-scene-broadcaster-system"
          name="gz::sim::systems::SceneBroadcaster"/>

  <!-- Sensor pipeline: renders lidar rays and camera frames (Ogre2) -->
  <plugin filename="gz-sim-sensors-system"
          name="gz::sim::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>

  <!-- IMU: integrates accelerometer + gyro data per-step -->
  <plugin filename="gz-sim-imu-system"
          name="gz::sim::systems::Imu"/>

  <!-- GPS / NavSat: GNSS position sensor -->
  <plugin filename="gz-sim-navsat-system"
          name="gz::sim::systems::NavSat"/>

  <!-- Contact: collision/touch sensors -->
  <plugin filename="gz-sim-contact-system"
          name="gz::sim::systems::Contact"/>

  <!-- ============================================================
       SCENE SETUP
  ============================================================ -->

  <!-- Directional sun light -->
  <light name="sun" type="directional">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 10 0 0 0</pose>
    <diffuse>0.8 0.8 0.8 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
    <direction>-0.5 0.1 -0.9</direction>
    <attenuation>
      <range>1000</range>
      <constant>0.9</constant>
      <linear>0.01</linear>
      <quadratic>0.001</quadratic>
    </attenuation>
  </light>

  <!-- Ground plane (grey, with friction for wheel contacts) -->
  <model name="ground_plane">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>100 100</size>
          </plane>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>100 100</size>
          </plane>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.4 0.4 0.4 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>
  </model>

  <!-- ============================================================
       LIDAR TARGETS
       Simple boxes at various distances so the LiDAR scan is not
       all max-range readings and is easy to verify visually.
  ============================================================ -->

  <model name="wall_north">
    <static>true</static>
    <pose>5 0 0.5 0 0 0</pose>
    <link name="link">
      <visual name="v"><geometry><box><size>0.2 4 1</size></box></geometry>
        <material><ambient>0.6 0.3 0.1 1</ambient><diffuse>0.6 0.3 0.1 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.2 4 1</size></box></geometry></collision>
    </link>
  </model>

  <model name="wall_east">
    <static>true</static>
    <pose>0 5 0.5 0 0 0</pose>
    <link name="link">
      <visual name="v"><geometry><box><size>4 0.2 1</size></box></geometry>
        <material><ambient>0.1 0.4 0.6 1</ambient><diffuse>0.1 0.4 0.6 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>4 0.2 1</size></box></geometry></collision>
    </link>
  </model>

  <model name="box_obstacle_1">
    <static>true</static>
    <pose>2 1 0.25 0 0 0</pose>
    <link name="link">
      <visual name="v"><geometry><box><size>0.5 0.5 0.5</size></box></geometry>
        <material><ambient>0.8 0.2 0.2 1</ambient><diffuse>0.8 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.5 0.5 0.5</size></box></geometry></collision>
    </link>
  </model>

  <model name="box_obstacle_2">
    <static>true</static>
    <pose>-2 -1.5 0.3 0 0 0.4</pose>
    <link name="link">
      <visual name="v"><geometry><box><size>0.4 0.8 0.6</size></box></geometry>
        <material><ambient>0.2 0.7 0.2 1</ambient><diffuse>0.2 0.7 0.2 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><box><size>0.4 0.8 0.6</size></box></geometry></collision>
    </link>
  </model>

  <model name="cylinder_obstacle">
    <static>true</static>
    <pose>3 -2 0.4 0 0 0</pose>
    <link name="link">
      <visual name="v"><geometry><cylinder><radius>0.3</radius><length>0.8</length></cylinder></geometry>
        <material><ambient>0.7 0.7 0.1 1</ambient><diffuse>0.7 0.7 0.1 1</diffuse></material>
      </visual>
      <collision name="c"><geometry><cylinder><radius>0.3</radius><length>0.8</length></cylinder></geometry></collision>
    </link>
  </model>

</world>
</sdf>
